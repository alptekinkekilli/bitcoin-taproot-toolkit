# Taproot Wallet — Ortam Değişkenleri Şablonu
# Bu dosyayı kopyala: cp .env.example .env
# .env dosyası git tarafından izlenmez (gitignored).

# ── Ağ ──────────────────────────────────────────────────────────
BITCOIN_NETWORK=testnet4   # testnet4 | mainnet

# ── Bitcoin Core RPC (isteğe bağlı) ─────────────────────────────
# USE_CORE_RPC=false → Esplora (mempool.space) API kullanılır, Core gerekmez.
# USE_CORE_RPC=true  → yerel Bitcoin Core node gerekir.
USE_CORE_RPC=false

# Aşağıdaki değerler yalnızca USE_CORE_RPC=true olduğunda gereklidir:
BITCOIN_RPCUSER=your_rpc_username
BITCOIN_RPCPASSWORD=your_rpc_password
BITCOIN_WALLET=taproot-wallet   # bitcoin-cli -named createwallet ile oluşturulan wallet
